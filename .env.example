# Local SQLite (optional)
SQLITE_DATABASE_PATH=./data/app.db

# Production Database (Supabase Postgres)
POSTGRES_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Shopify OAuth Configuration (Required for auto-connection)
SHOPIFY_API_KEY=your_shopify_api_key_from_partner_dashboard
SHOPIFY_API_SECRET=your_shopify_api_secret_from_partner_dashboard
SHOPIFY_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_SHOPIFY_API_KEY=your_shopify_api_key_from_partner_dashboard

# For local development with ngrok
# SHOPIFY_APP_URL=https://your-ngrok-url.ngrok.io

# App Settings
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Bulk Price Editor"
