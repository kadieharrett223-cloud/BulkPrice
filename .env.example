# Database URL (optional, defaults to ./data/app.db)
# DATABASE_URL=/path/to/database.db

# Shopify API Settings (can be set in app)
# SHOPIFY_API_KEY=your_api_key
# SHOPIFY_API_PASSWORD=your_api_password
# SHOPIFY_SHOP=yourstore.myshopify.com

# App Settings
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Bulk Price Editor"
